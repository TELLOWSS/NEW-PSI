{
  "name": "new-psi",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:api": "vercel dev --listen 3001",
    "dev:all": "concurrently -k -n WEB,API -c cyan,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "check:context": "node scripts/check-repo-context.cjs",
    "check:hotspot": "node scripts/check-hotspot-syntax.cjs",
    "check:tdz": "node scripts/check-tdz-useeffect-order.cjs",
    "check:page-tone": "node scripts/check-page-tone-coverage.cjs",
    "check:score-consistency": "node scripts/check-score-consistency-gate.cjs",
    "check:score-consistency:strict": "node scripts/check-score-consistency-gate.cjs --strict",
    "check:score-consistency:strict8": "node scripts/check-score-consistency-gate.cjs --strict --max-gap 8",
    "check:score-consistency:report": "node scripts/check-score-consistency-gate.cjs --report-json reports/score-consistency.json --report-md reports/score-consistency.md",
    "check:score-consistency:report:strict8": "node scripts/check-score-consistency-gate.cjs --strict --max-gap 8 --report-json reports/score-consistency-strict8.json --report-md reports/score-consistency-strict8.md",
    "check:types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:fast": "npm run check:context && npm run check:hotspot && npm run check:tdz && npm run check:page-tone && npm run check:ocr-contract && npm run check:score-consistency:strict8 && npm run check:types",
    "verify:release": "npm run verify:fast && npm run check:score-consistency:report:strict8 && npm run build",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@google/genai": "^1.28.0",
    "@supabase/supabase-js": "^2.57.2",
    "chart.js": "^4.5.1",
    "html-to-image": "^1.11.13",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-signature-canvas": "1.0.7",
    "recharts": "^3.8.1",
    "solapi": "^5.5.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "typescript": "~5.8.2",
    "vercel": "^39.4.0",
    "vite": "^6.2.0"
  }
}
