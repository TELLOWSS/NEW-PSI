{
  "name": "new-psi",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/auto-daily-bootstrap.cjs",
    "dev": "vite",
    "dev:web": "vite",
    "dev:api": "node scripts/run-vercel-dev.cjs",
    "dev:all": "concurrently -k -n WEB,API -c cyan,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "check:context": "node scripts/check-repo-context.cjs",
    "check:hotspot": "node scripts/check-hotspot-syntax.cjs",
    "check:tdz": "node scripts/check-tdz-useeffect-order.cjs",
    "check:page-tone": "node scripts/check-page-tone-coverage.cjs",
    "check:ocr-contract": "node scripts/check-ocr-contract.cjs",
    "check:security-headers": "node scripts/check-security-headers.mjs",
    "check:judgment-tagging": "node scripts/check-judgment-tagging-quality.cjs",
    "check:judgment-tagging:blank100": "node scripts/check-judgment-tagging-quality.cjs --input templates/psi_judgment_tagging_blank_100rows_v1_2026-05-16.csv",
    "check:judgment-tagging:report": "node scripts/check-judgment-tagging-quality.cjs --report-json reports/judgment-tagging-quality.json --report-md reports/judgment-tagging-quality.md",
    "report:judgment-tagging:ops-summary": "node scripts/generate-judgment-tagging-ops-summary.cjs --input reports/judgment-tagging-quality.json --output reports/judgment-tagging-ops-summary.md",
    "check:judgment-tagging:full": "npm run check:judgment-tagging:report && npm run report:judgment-tagging:ops-summary",
    "report:judgment-tagging:r1-closeout": "node scripts/generate-judgment-tagging-r1-closeout.cjs --round R1 --tracker templates/psi_judgment_tagging_progress_tracker_100_v1_2026-05-16.csv --ops-summary reports/judgment-tagging-ops-summary.md --output reports/judgment-tagging-r1-closeout.md",
    "check:judgment-tagging:r1:full": "npm run check:judgment-tagging:full && npm run report:judgment-tagging:r1-closeout",
    "check:score-consistency": "node scripts/check-score-consistency-gate.cjs",
    "check:score-consistency:strict": "node scripts/check-score-consistency-gate.cjs --strict",
    "check:score-consistency:strict8": "node scripts/check-score-consistency-gate.cjs --strict --max-gap 8",
    "check:score-consistency:report": "node scripts/check-score-consistency-gate.cjs --report-json reports/score-consistency.json --report-md reports/score-consistency.md",
    "check:score-consistency:report:strict8": "node scripts/check-score-consistency-gate.cjs --strict --max-gap 8 --report-json reports/score-consistency-strict8.json --report-md reports/score-consistency-strict8.md",
    "check:mobile-qa:evidence": "node scripts/check-mobile-qa-evidence.cjs",
    "check:mobile-qa:evidence:report": "node scripts/check-mobile-qa-evidence.cjs --write-report",
    "qa:mobile:capture": "node scripts/capture-mobile-qa-evidence.cjs",
    "qa:mobile:autoflow": "npm run build && npm run qa:mobile:capture && npm run check:mobile-qa:evidence:report && npm run qa:mobile:finalize",
    "qa:mobile:ready": "npm run build && npm run qa:mobile:capture && npm run check:mobile-qa:evidence",
    "qa:survey-baseline": "node scripts/verify-survey-baseline-ui.mjs",
    "qa:plain-language": "node scripts/verify-plain-language-ui.mjs",
    "qa:worker-report": "node scripts/verify-worker-report-ui.mjs",
    "qa:safety-case": "node scripts/verify-safety-case-closed-loop-ui.mjs",
    "sync:mobile-qa:status": "node scripts/sync-mobile-qa-status.cjs",
    "qa:mobile:refresh": "node scripts/refresh-mobile-qa-status.cjs",
    "qa:mobile:finalize": "node scripts/finalize-mobile-qa-status.cjs",
    "analyze:policy-impact": "node scripts/analyze-operational-penalty-impact.cjs --input reports/records-export.json --output-json reports/policy-impact.json --output-md reports/policy-impact.md",
    "analyze:policy-impact:onepager": "node scripts/generate-policy-impact-onepager.cjs --input reports/policy-impact.json --output reports/policy-impact-onepager.md",
    "analyze:policy-impact:full": "npm run analyze:policy-impact && npm run analyze:policy-impact:onepager",
    "analyze:backfill-readiness": "node scripts/analyze-backfill-readiness.cjs --input reports/records-export.json --output-json reports/backfill-readiness.json --output-md reports/backfill-readiness.md",
    "analyze:backfill-readiness:tuned": "node scripts/analyze-backfill-readiness.cjs --input reports/records-export.json --output-json reports/backfill-readiness.json --output-md reports/backfill-readiness.md --est-input-tokens 900 --est-output-tokens 350 --ocr-input-tokens 1800 --ocr-output-tokens 250 --cost-input-1k 0.002 --cost-output-1k 0.006",
    "audit:data": "node scripts/audit-data.mjs",
    "audit:productization": "node scripts/audit-productization.mjs",
    "audit:ui-language": "node scripts/audit-ui-language.mjs",
    "check:ui-language": "node scripts/audit-ui-language.mjs --strict",
    "audit:report-language": "node scripts/audit-report-language.mjs",
    "check:report-language": "node scripts/audit-report-language.mjs --strict",
    "log:story": "node scripts/append-upgrade-story-log.cjs",
    "log:story:auto": "node scripts/append-upgrade-story-log.cjs --auto-from-reports",
    "log:story:auto:delta": "node scripts/append-upgrade-story-log.cjs --auto-from-reports",
    "log:story:auto:no-delta": "node scripts/append-upgrade-story-log.cjs --auto-from-reports --no-delta",
    "log:story:today": "node scripts/append-upgrade-story-log.cjs --date 2026-04-22 --change \"오늘 변경사항 입력\" --impact \"비용/품질/재현성 영향 입력\" --next \"내일 첫 작업 입력\"",
    "log:story:auto:today": "node scripts/append-upgrade-story-log.cjs --auto-from-reports --date 2026-04-22 --change \"오늘 변경사항 입력\" --next \"내일 첫 작업 입력\"",
    "ops:auto:daily": "node scripts/auto-daily-bootstrap.cjs",
    "check:types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:fast": "npm run check:context && npm run check:hotspot && npm run check:tdz && npm run check:page-tone && npm run check:ocr-contract && npm run check:security-headers && npm run check:ui-language && npm run check:report-language && npm run check:score-consistency:strict8 && npm run check:types",
    "verify:release": "npm run verify:fast && npm run check:score-consistency:report:strict8 && npm run build",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@google/genai": "^1.28.0",
    "@supabase/supabase-js": "^2.57.2",
    "chart.js": "^4.5.1",
    "html-to-image": "^1.11.13",
    "pdfjs-dist": "^6.0.227",
    "pptxgenjs": "^4.0.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-signature-canvas": "1.0.7",
    "recharts": "^3.8.1",
    "solapi": "^5.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.9"
  }
}
